WHATSAPP_PROVIDER=wati
WHATSAPP_API_KEY=
WHATSAPP_BASE_URL=
WHATSAPP_NUMBER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GST_PROVIDER=nic
GST_GSTIN=
GST_SANDBOX=true
GST_CLIENT_ID=
GST_CLIENT_SECRET=
GST_USERNAME=
GST_PASSWORD=
GST_APP_KEY=
EINVOICE_BASE_URL=einv-apisandbox.nic.in
EWAYBILL_BASE_URL=einv-apisandbox.nic.in
GST_FILING_BASE_URL=
GST_FILING_API_KEY=
# AI Copilot — OpenAI-compatible provider (default: Groq). Set AI_API_KEY to a Groq key
# (https://console.groq.com/keys). To use another provider, also set AI_BASE_URL + AI_MODEL.
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# Gemini — powers the bill-scan (image → draft voucher) and, if AI_API_KEY above is left
# blank, the Copilot chat too (via Gemini's OpenAI-compatible endpoint). Get a key at
# https://aistudio.google.com/apikey. Default model gemini-2.5-flash (multimodal).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
