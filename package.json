{
  "name": "Startup",
  "version": "1.0.0",
  "description": "Startup App",
  "author": {
    "name": "Darshan Kochar",
    "email": "dev@startup.com"
  },
  "main": "main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "npm --prefix client install",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:client": "cd client && npm run lint",
    "typecheck:client": "cd client && tsc -b",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit",
    "dev:client": "cd client && npm run dev",
    "dev": "cd client && npm run dev",
    "electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "mcp": "node server/mcp/run.js",
    "docs:gen": "node server/docs/genStatic.js",
    "docs:check": "node server/docs/checkDocs.js",
    "docs:db": "node server/docs/dbDocsGenerator.js",
    "db:parity": "node server/db/parityCheck.js",
    "db:verify-migration": "node server/db/verifyMigration.js",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.config.sqlite.js",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.config.pg.js",
    "db:generate": "npm run db:generate:sqlite && npm run db:generate:pg",
    "db:migrate": "node server/db/migrate.js",
    "db:repair": "node server/db/repair.js",
    "build:client": "cd client && npm run build",
    "dist": "npm run build:client && electron-builder",
    "dist:win": "npm run build:client && electron-builder --win --publish never",
    "dist:mac": "npm run build:client && electron-builder --mac --publish never",
    "dist:linux": "npm run build:client && electron-builder --linux --publish never",
    "e2e": "playwright test"
  },
  "build": {
    "appId": "com.startup.app",
    "productName": "Startup",
    "asar": false,
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "dev@startup.com"
    },
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "client/dist/**/*",
      "node_modules/**/*"
    ]
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.0",
    "prettier": "^3.9.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@hono/node-server": "^2.0.5",
    "@libsql/client": "^0.17.3",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.0",
    "fastmcp": "^4.3.0",
    "hono": "^4.12.25",
    "pg": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/server/tests/**/*.test.js"
    ]
  },
  "lint-staged": {
    "*.{js,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "client/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{mjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
